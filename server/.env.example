# ============================================================
# Review Reply AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control!
# ============================================================

# --- REQUIRED ---

# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Port the server listens on (Railway/Render set this automatically)
PORT=3000

# --- OPTIONAL ---

# Your Stripe secret key (for handling subscriptions)
STRIPE_KEY=sk_test_your_stripe_key_here

# Stripe webhook secret (for verifying webhook events)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Restrict CORS to your frontend domain (leave * for local dev)
ALLOWED_ORIGIN=https://yourdomain.com
